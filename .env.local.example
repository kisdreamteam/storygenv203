# Project URL from Supabase → Settings → API (NOT the REST path)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: for `node scripts/apply-migration.mjs` only (Database URI from Supabase dashboard)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Vercel: add the same three variables in Project → Settings → Environment Variables
# (Production + Preview). URL must end with .supabase.co — do not use /rest/v1/
